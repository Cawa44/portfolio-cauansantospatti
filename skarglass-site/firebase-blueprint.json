{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastComplexity": { "type": "number" },
        "lastContrast": { "type": "number" },
        "lastColor": { "type": "string" },
        "lastForm": { "type": "string" },
        "lastStyleMode": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "BlobHistory": {
      "title": "BlobHistory",
      "description": "History of generated blobs",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner UID" },
        "path": { "type": "string", "description": "SVG path data" },
        "color": { "type": "string" },
        "complexity": { "type": "number" },
        "contrast": { "type": "number" },
        "form": { "type": "string" },
        "styleMode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "path", "color", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User specific settings and profile"
    },
    "/users/{userId}/history/{blobId}": {
      "schema": "BlobHistory",
      "description": "History of blobs generated by the user"
    }
  }
}
